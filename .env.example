# ─────────────────────────────────────────────────────────────────────────────
# hermes-headroom configuration. A copy is created automatically by ./setup.sh.
# Edit values here; nothing secret ever goes into the scripts themselves.
# ─────────────────────────────────────────────────────────────────────────────

# Your OpenRouter API key. Get one at https://openrouter.ai/keys
# This is the ONLY place your key lives. The proxy reads it; Hermes never sees it.
OPENROUTER_API_KEY=

# NOTE: routing is global via OPENROUTER_BASE_URL in ~/.hermes/.env — install.sh
# does NOT rewrite your model/provider, so MODEL and CONTEXT_LENGTH below are only
# used as defaults/informational. Keep choosing models the normal Hermes way
# (config.yaml / `hermes model` / per profile); whatever you pick still flows
# through the proxy as long as it uses the openrouter provider.

# OpenRouter model id (informational). Browse the catalog at https://openrouter.ai/models
MODEL=deepseek/deepseek-v4-flash

# Context window hint (informational; not forced onto any config).
CONTEXT_LENGTH=1000000

# Local port for the Headroom proxy. Change only if 8787 is already taken.
PORT=8787

# Make `headroom perf` show $ savings for brand-new models (e.g. deepseek-v4-*)
# that aren't in LiteLLM's price DB yet. install.sh registers their live
# OpenRouter prices into LiteLLM's *local* cost map; this flag tells LiteLLM to
# use that local map (instead of fetching the remote one, which lacks them).
# Also deterministic + offline-friendly for an always-on service.
LITELLM_LOCAL_MODEL_COST_MAP=true

# Anonymous usage telemetry is ON by default upstream. Off here to keep an
# always-on agent's activity private; set to `on` if you'd like to support the
# Headroom project with anonymous metrics.
HEADROOM_TELEMETRY=off

# Compression mode (read natively by the proxy). This is NOT forced — it just
# makes Headroom's own default (token) visible and easy to change.
#   token  = max token reduction; rewrites prior turns (can churn prefix cache early)
#   cache  = freeze prior turns to maximise provider prefix-cache hits (lower $ on
#            steep-cache-discount models like deepseek-v4-pro). One proxy = one
#            mode; there is no per-model auto-switch today (would be a Headroom
#            feature). For flash/minimax-dominant traffic, token usually wins.
# Test both, then compare `headroom perf` (token reduction vs cache hit rate / bill).
HEADROOM_MODE=token

# ── Compression tuning (all read natively by the proxy from this file) ─────────
# AST-based code compression. Default OFF upstream only for back-compat, not
# quality — recommended ON for code-heavy agents (uses the bundled ast-grep).
HEADROOM_CODE_AWARE_ENABLED=1

# Harder compression of tool / Read outputs (ast-grep Read outliner, etc.).
# EXPERIMENTAL — upstream keeps it off "while this feature ships". Promising for
# file-reading crons; trial it and watch the agents before trusting it. (1 = on)
#HEADROOM_INTERCEPT_ENABLED=1

# Daily spend cap in USD for the always-on proxy (safety net). Unset = no cap.
#HEADROOM_BUDGET=5

# Opt-in proxy extensions by entry-point name (advanced). '*' = all discovered.
#HEADROOM_PROXY_EXTENSIONS=

# NOTE: do NOT confuse `cache` MODE (above) with `--no-cache`. `--no-cache`
# disables Headroom's OWN internal semantic/compression cache (a separate thing
# from the provider prefix cache that `cache` mode targets) — you almost never
# want it. If you ever do, put it in HEADROOM_EXTRA_ARGS below.

# Add Headroom's MCP retrieve tool to the DEFAULT Hermes config only (1 = on,
# 0 = off) so interactive/default sessions can call headroom_retrieve to pull
# back original, uncompressed content. Not global (MCP has no env lever).
ENABLE_MCP=1

# ── Persistent memory / SharedContext ──────────────────────────────────────────
# When enabled, the proxy automatically extracts important facts from
# conversations and injects relevant compressed memories into future requests.
# This is the proxy-level equivalent of Headroom's SharedContext Python API —
# when agent A discovers something and agent B starts a new session, the proxy
# injects relevant compressed memories automatically. ~80% token savings on
# inter-agent handoffs with no code changes needed.
#
#   --memory              Enable persistent memory (auto-injects relevant context)
#   --memory-storage      project = per-project DB (default), user = single DB
#                         for all traffic (recommended for Hermes, where all
#                         conversations share one proxy)
#   --memory-top-k N      How many memories to inject (default: 10)
#   --learn               Also extract error→recovery patterns from traffic
#                         (implies --memory). Saves to MEMORY.md / AGENTS.md.
#   --no-memory-tools     Disable auto-injected memory tools (headroom_remember etc.)
#   --no-memory-context   Disable auto memory context injection
#
# Memory management CLI:
#   headroom memory list              List stored memories
#   headroom memory stats             Show memory statistics
#   headroom memory prune --older-than 30d  Prune old memories
#
# Set to blank to disable memory entirely.
HEADROOM_EXTRA_ARGS="--memory --memory-storage=user"

# Anything else passed straight to `headroom proxy` (rarely needed; the options
# above cover the common cases). Example: HEADROOM_EXTRA_ARGS="--no-cache"
# (NOTE: HEADROOM_EXTRA_ARGS above already includes --memory flags; append to it
# rather than overwriting if you need additional proxy flags.)
