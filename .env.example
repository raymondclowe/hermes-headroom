# ─────────────────────────────────────────────────────────────────────────────
# hermes-headroom configuration. A copy is created automatically by ./setup.sh.
# Edit values here; nothing secret ever goes into the scripts themselves.
# ─────────────────────────────────────────────────────────────────────────────

# Your OpenRouter API key. Get one at https://openrouter.ai/keys
# This is the ONLY place your key lives. The proxy reads it; Hermes never sees it.
OPENROUTER_API_KEY=

# OpenRouter model id to use. Browse the catalog at https://openrouter.ai/models
# Default below is DeepSeek V4 Flash (fast, ~1M context, very cheap).
MODEL=deepseek/deepseek-v4-flash

# Context window (in tokens) Hermes should assume for this model.
# DeepSeek V4 Flash supports ~1M tokens. 64000 is Hermes' minimum for agent use.
CONTEXT_LENGTH=1000000

# Local port for the Headroom proxy. Change only if 8787 is already taken.
PORT=8787

# Wire Headroom's MCP server into Hermes (1 = on, 0 = off) so the agent can call
# headroom_retrieve / headroom_stats to pull back original, uncompressed content.
ENABLE_MCP=1

# Optional advanced flags passed straight to `headroom proxy`. Usually leave blank.
# Example: HEADROOM_EXTRA_ARGS="--budget 50 --log-file ./.runtime/headroom.jsonl"
HEADROOM_EXTRA_ARGS=
